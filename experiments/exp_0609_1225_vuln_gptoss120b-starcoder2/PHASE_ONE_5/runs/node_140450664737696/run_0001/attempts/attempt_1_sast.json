      "test_name_raw": "py/path-injection",
      "judge_verdict": "TP",
      "judge_reason": "Same validation issue. The `name` parameter from query string is split naively and can contain `../` which passes `is_valid_filename` and allows reading files outside CONFIG_DIR."
    }
