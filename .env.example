# Local Hugging Face Transformers cache/home.
HF_HOME=~/.cache/huggingface

# Optional Hugging Face config for agent_config_vul.yml.
# Not needed when using agent_config_vul_hf_local.yml unless the model download
# requires authentication.
# HF_TOKEN=hf_your_token_here
# HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

# The vulnerability judge remains configurable separately.
DEEPSEEK_API_KEY=your_deepseek_api_key

# Optional dedicated Hugging Face endpoint for semantic embeddings.
# HUGGINGFACE_EMBEDDINGS_BASE_URL=https://your-endpoint.endpoints.huggingface.cloud
